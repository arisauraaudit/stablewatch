# Copy this to .env for local testing, or set as Railway environment variables

# Required: your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Required: the Telegram channel/chat to post alerts to
# Use @yourchannel (public) or a numeric chat_id (private channel)
TELEGRAM_CHANNEL=@depegalerts

# Optional: polling interval in seconds (default 60)
POLL_INTERVAL=60

# Optional: path to SQLite database file (default: depeg_events.db)
DB_PATH=depeg_events.db
